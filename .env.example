# ==============================
# AI Product Launch Agent config
# Copy this file to `.env` and fill real values.
# ==============================

# --- LLM (required) ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Web research ---
TAVILY_API_KEY=your_tavily_api_key

# --- Image generation  ---
# Any one of these token names can work in backend.py; HF_TOKEN is preferred.
HF_API_KEY=your_huggingface_key
# HF_TOKEN=
# HUGGINGFACEHUB_API_TOKEN=
# HUGGINGFACE_API_KEY=

# Optional model override
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# --- LangSmith tracing ---
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=product-launch-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# --- LangChain compatibility fallback (only if traces do not appear) ---
# LANGCHAIN_API_KEY=your_langchain_api_key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=product-launch-agent
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
